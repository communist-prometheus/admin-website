# GitHub OAuth App
VITE_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Set to 'true' to enable mock user for UI development
VITE_MOCK_AUTH=false
MOCK_OAUTH=false

# GitHub Content Repository
GITHUB_BRANCH=main
GITHUB_E2E_KEY=your_github_pat_for_e2e_tests

# Service Worker Git BFF (client-side)
VITE_GITHUB_OWNER=communist-prometheus
VITE_GITHUB_REPO=public-website-content
VITE_GITHUB_BRANCH=develop
VITE_GITHUB_CONTENT_PATH=
VITE_CORS_PROXY=https://cors.isomorphic-git.org
