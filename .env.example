GITHUB_CLIENT_ID=your_github_app_client_id
GITHUB_CLIENT_SECRET=your_github_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
SESSION_SECRET=your_random_session_secret_minimum_32_characters_required_here

# GitHub Content Repository
GITHUB_OWNER=communist-prometheus
GITHUB_REPO=public-website
GITHUB_TOKEN=your_github_personal_access_token_with_repo_permissions
GITHUB_BRANCH=main
GITHUB_CONTENT_PATH=src/content

# Set to 'true' to enable mock user for UI development (no real GitHub login required)
VITE_MOCK_AUTH=false
MOCK_OAUTH=false
