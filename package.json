{
  "name": "admin-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "bun src/server.ts",
    "validate": "bun run type-check && bun run check:ci && bun run lint:sonar && bun run lint:jsdoc && bun run lint:css",
    "prebuild": "bun run validate",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.ts",
    "preview": "cross-env NODE_ENV=production bun src/server.ts",
    "preview:test": "cross-env NODE_ENV=production MOCK_OAUTH=true bun src/server.ts",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e": "cross-env MOCK_OAUTH=true playwright test",
    "test:e2e:ui": "cross-env MOCK_OAUTH=true playwright test --ui",
    "test:e2e:debug": "cross-env MOCK_OAUTH=true playwright test --debug",
    "type-check": "vue-tsc --build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint --write .",
    "lint:check": "biome lint .",
    "lint:sonar": "oxlint --config .oxlintrc.json",
    "lint:jsdoc": "eslint --config eslint.config.js --max-warnings 0 \"src/**/*.{ts,vue}\"",
    "lint:css": "stylelint \"**/*.{css,vue}\"",
    "lint:css:fix": "stylelint \"**/*.{css,vue}\" --fix",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "check:all": "bun run type-check && bun run check && bun run lint:sonar && bun run lint:css"
  },
  "dependencies": {
    "@effect/schema": "^0.75.5",
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.0.0",
    "dotenv": "^17.3.1",
    "effect": "^3.19.18",
    "fastify": "^5.7.4",
    "pinia": "^3.0.4",
    "vue": "beta",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@fastify/middie": "^9.1.0",
    "@playwright/test": "^1.58.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "eslint-plugin-comments": "^1.0.0",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.6.3",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxlint": "1.48.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.3.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "beta",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "overrides": {
    "vue": "beta",
    "@vue/compiler-core": "beta",
    "@vue/compiler-dom": "beta",
    "@vue/compiler-sfc": "beta",
    "@vue/compiler-ssr": "beta",
    "@vue/compiler-vapor": "beta",
    "@vue/reactivity": "beta",
    "@vue/runtime-core": "beta",
    "@vue/runtime-dom": "beta",
    "@vue/runtime-vapor": "beta",
    "@vue/server-renderer": "beta",
    "@vue/shared": "beta",
    "@vue/compat": "beta"
  }
}
