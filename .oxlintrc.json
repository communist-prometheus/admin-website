{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "vue",
    "vitest",
    "jsx-a11y"
  ],
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "jsPlugins": ["eslint-plugin-sonarjs"],
  "rules": {
    "no-console": "error",
    "no-inline-comments": "error",
    "no-warning-comments": "error",
    "typescript/explicit-member-accessibility": [
      "error",
      { "accessibility": "explicit" }
    ],
    "sonarjs/cognitive-complexity": ["error", 15],
    "sonarjs/no-duplicate-string": ["error", { "threshold": 3 }],
    "sonarjs/no-identical-functions": "error",
    "sonarjs/no-redundant-boolean": "error",
    "sonarjs/no-unused-collection": "error",
    "sonarjs/no-use-of-empty-return-value": "error",
    "sonarjs/prefer-immediate-return": "error",
    "sonarjs/prefer-object-literal": "error",
    "sonarjs/prefer-single-boolean-return": "error",
    "sonarjs/max-lines": ["error", { "maximum": 50 }],
    "sonarjs/max-lines-per-function": ["error", { "maximum": 30 }],
    "vue/no-restricted-html-elements": [
      "error",
      {
        "element": "div",
        "message": "<div> is prohibited. Create child components instead. Use :host for container styles."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/!(example)/**/*.vue",
        "src/App.vue",
        "src/components/*.vue",
        "src/views/**/*.vue"
      ],
      "rules": {
        "vue/no-restricted-html-elements": "off"
      }
    },
    {
      "files": [
        "src/server/oauth/github/handlers/callback.ts",
        "src/server/oauth/github/utils.ts",
        "src/server/ssr/page-renderer.ts",
        "src/server/setup/renderer.ts",
        "src/server/setup/fastify-plugins.ts",
        "src/server/setup/routes.ts"
      ],
      "rules": {
        "sonarjs/max-lines": "off",
        "sonarjs/max-lines-per-function": "off"
      }
    }
  ],
  "ignorePatterns": [
    "e2e/auth.spec.ts",
    "eslint.config.js",
    "src/auto-imports.d.ts",
    "src/components.d.ts"
  ]
}
