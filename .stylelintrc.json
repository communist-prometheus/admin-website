{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-recommended-vue"
  ],
  "ignoreFiles": ["dist/**/*", "node_modules/**/*"],
  "rules": {
    "max-nesting-depth": [3, { "severity": "error" }],
    "selector-max-compound-selectors": [3, { "severity": "error" }],
    "selector-max-specificity": ["0,3,0", { "severity": "error" }],
    "declaration-block-no-redundant-longhand-properties": [
      true,
      { "severity": "error" }
    ],
    "shorthand-property-no-redundant-values": [true, { "severity": "error" }],
    "color-named": ["never", { "severity": "error" }],
    "font-weight-notation": ["numeric", { "severity": "error" }],
    "length-zero-no-unit": [true, { "severity": "error" }],
    "declaration-no-important": [true, { "severity": "error" }],
    "selector-no-qualifying-type": [
      true,
      { "ignore": ["attribute"], "severity": "error" }
    ],
    "no-duplicate-selectors": [true, { "severity": "error" }],
    "declaration-block-single-line-max-declarations": [
      1,
      { "severity": "error" }
    ],
    "selector-class-pattern": [
      "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      { "severity": "error" }
    ],
    "custom-property-pattern": [
      "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      { "severity": "error" }
    ],
    "color-hex-length": ["short", { "severity": "error" }],
    "color-function-notation": ["modern", { "severity": "error" }],
    "alpha-value-notation": ["percentage", { "severity": "error" }],
    "selector-pseudo-element-colon-notation": [
      "double",
      { "severity": "error" }
    ]
  }
}
